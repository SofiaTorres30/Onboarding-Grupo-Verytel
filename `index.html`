<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tablero Onboarding - Grupo Verytel</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            background: white;
            border-radius: 12px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        header h1 {
            color: #12192B;
            margin-bottom: 10px;
            font-size: 28px;
        }

        header .meta {
            color: #666;
            font-size: 14px;
        }

        .loading {
            text-align: center;
            padding: 40px;
            background: white;
            border-radius: 12px;
            color: #667eea;
            font-size: 18px;
        }

        .error {
            background: #ff6b6b;
            color: white;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            text-align: center;
        }

        .areas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .area-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            cursor: pointer;
            transition: all 0.3s ease;
            border-left: 5px solid #C9872A;
        }

        .area-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

        .area-card h3 {
            color: #12192B;
            margin-bottom: 10px;
            font-size: 18px;
        }

        .area-card .info {
            font-size: 12px;
            color: #999;
            margin-bottom: 10px;
        }

        .folder-count {
            background: #f0f0f0;
            color: #667eea;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: bold;
            display: inline-block;
        }

        .contenido-expandible {
            margin-top: 15px;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .area-card.expanded .contenido-expandible {
            max-height: 500px;
        }

        .contenido-expandible ul {
            list-style: none;
            padding-left: 20px;
        }

        .contenido-expandible li {
            padding: 5px 0;
            color: #666;
            font-size: 13px;
            border-bottom: 1px solid #f0f0f0;
        }

        .contenido-expandible li:before {
            content: "📁 ";
            margin-right: 8px;
        }

        .stats {
            background: white;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 32px;
            font-weight: bold;
            color: #667eea;
        }

        .stat-label {
            font-size: 12px;
            color: #999;
            margin-top: 5px;
            text-transform: uppercase;
        }

        footer {
            text-align: center;
            color: white;
            margin-top: 40px;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>📊 Tablero Onboarding - Grupo Verytel</h1>
            <div class="meta">
                <span id="status">⏳ Cargando datos...</span>
                <span id="timestamp" style="display: none; margin-left: 20px;">Actualizado: <strong></strong></span>
            </div>
        </header>

        <div id="loading" class="loading">
            ⏳ Cargando estructura de OneDrive...
        </div>

        <div id="error" class="error" style="display: none;"></div>

        <div id="content" style="display: none;">
            <div class="stats" id="stats"></div>
            <div class="areas-grid" id="areas"></div>
        </div>

        <footer>
            <p>Actualización automática cada día a las 7:00 AM • Datos almacenados localmente • <a href="#" style="color: white;" onclick="reloadData(); return false;">🔄 Recargar ahora</a></p>
        </footer>
    </div>

    <script>
        // Cargar datos del JSON
        async function loadOnboardingData() {
            try {
                console.log("📥 Obteniendo datos de data/onboarding.json...");
                
                const response = await fetch('data/onboarding.json');
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const datos = await response.json();
                
                console.log("✅ Datos cargados correctamente", datos);
                
                renderDatos(datos);
                
                // Guardar en localStorage para caché
                localStorage.setItem('onboardingData', JSON.stringify(datos));
                localStorage.setItem('onboardingDataTimestamp', new Date().getTime());
                
            } catch (error) {
                console.error("❌ Error al cargar datos:", error);
                
                // Intentar usar datos en caché
                const cached = localStorage.getItem('onboardingData');
                if (cached) {
                    console.log("⚠️ Usando datos en caché...");
                    renderDatos(JSON.parse(cached));
                    document.querySelector('#error').style.display = 'block';
                    document.querySelector('#error').innerHTML = `
                        ⚠️ No se pudo conectar al servidor. Mostrando datos en caché.
                        <br><small>Último acceso: ${new Date(parseInt(localStorage.getItem('onboardingDataTimestamp'))).toLocaleString('es-CO')}</small>
                    `;
                } else {
                    showError("Error al cargar los datos: " + error.message);
                }
            }
        }

        function renderDatos(datos) {
            // Ocultar loading
            document.querySelector('#loading').style.display = 'none';
            document.querySelector('#content').style.display = 'block';

            // Actualizar timestamp
            const timestamp = document.querySelector('#timestamp');
            timestamp.style.display = 'inline';
            timestamp.querySelector('strong').textContent = new Date(datos.fecha_generacion).toLocaleString('es-CO');

            // Renderizar estadísticas
            const stats = document.querySelector('#stats');
            stats.innerHTML = `
                <div class="stat-item">
                    <div class="stat-value">${datos.total_carpetas || 0}</div>
                    <div class="stat-label">Carpetas</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">${(datos.areas || []).length}</div>
                    <div class="stat-label">Áreas</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value">✅</div>
                    <div class="stat-label">Sincronizado</div>
                </div>
            `;

            // Renderizar áreas
            const areasContainer = document.querySelector('#areas');
            areasContainer.innerHTML = '';

            (datos.areas || []).forEach((area, index) => {
                const card = document.createElement('div');
                card.className = 'area-card';
                
                const contenidoHtml = (area.contenido || [])
                    .map(item => `<li>${item.nombre}</li>`)
                    .join('');

                card.innerHTML = `
                    <h3>${area.nombre}</h3>
                    <div class="info">
                        Tipo: <strong>${area.tipo}</strong>
                        ${area.tamaño ? `| Tamaño: ${formatBytes(area.tamaño)}` : ''}
                    </div>
                    ${area.contenido && area.contenido.length > 0 ? `
                        <div class="folder-count">${area.contenido.length} elementos</div>
                        <div class="contenido-expandible">
                            <ul>${contenidoHtml}</ul>
                        </div>
                    ` : ''}
                `;

                card.addEventListener('click', () => {
                    card.classList.toggle('expanded');
                });

                areasContainer.appendChild(card);
            });

            // Actualizar estado
            document.querySelector('#status').textContent = '✅ Datos cargados correctamente';
        }

        function showError(message) {
            document.querySelector('#loading').style.display = 'none';
            const errorDiv = document.querySelector('#error');
            errorDiv.style.display = 'block';
            errorDiv.textContent = '❌ ' + message;
        }

        function formatBytes(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        function reloadData() {
            document.querySelector('#loading').style.display = 'block';
            document.querySelector('#content').style.display = 'none';
            document.querySelector('#error').style.display = 'none';
            loadOnboardingData();
        }

        // Cargar datos al iniciar
        window.addEventListener('DOMContentLoaded', loadOnboardingData);
    </script>
</body>
</html>
